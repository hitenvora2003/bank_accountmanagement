<%- include('../partials/header') %>

    <div id="app">

                <div id="auth-screen">
                    <div class="auth-box">
                        <div class="auth-logo">
                            <div class="logo-mark">N</div>
                            <span style="font-family: &quot;Playfair Display&quot;, serif;font-size: 24px;font-weight: 600;color: var(--gold);">NovaPay</span>
                        </div>
                        <div class="auth-title">Welcome Back</div>
                        <div class="auth-sub">Sign in to your banking portal</div>
                        <div class="auth-tab">
                            <button class="auth-tab-btn active" onclick="switchAuth('login')">
                                Sign In
                            </button>
                            <button class="auth-tab-btn" onclick="switchAuth('register')">
                                Register
                            </button>
                            <button class="auth-tab-btn" onclick="switchAuth('forgot')">
                                Forgot
                            </button>
                        </div>

                        <!-- LOGIN -->
                        <form class="auth-form active" id="login-form" onsubmit="doLogin(event)">
                            <div class="form-group">
                                <label>Email</label>
                                <input type="text" id="login-email" placeholder="email@example.com" required />
                            </div>
                            <div class="form-group">
                                <label>Password</label>
                                <input type="password" id="login-pass" placeholder="••••••••" required />
                                <div class="forgot-link" onclick="switchAuth('forgot')">
                                    Forgot password?
                                </div>
                            </div>
                            <button class="btn btn-primary" type="submit"
                                style="margin-top: 4px; justify-content: center">
                                Sign In
                            </button>
                            <div style="font-size: 12px;color: var(--text-muted);text-align: center;">
                                Demo: use any credentials — connect to your backend API
                            </div>
                        </form>
            </main>

    </div>

    <%- include('../partials/footer') %>