<%- include('../partials/header') %>
<section style="padding:40px;max-width:500px;margin:auto;">
  <h1>Create Account</h1>
  <form action="/register" method="POST">
    <input type="text" name="name" placeholder="Full Name" required class="form-control"/><br/><br/>
    <input type="email" name="email" placeholder="Email" required class="form-control"/><br/><br/>
    <input type="number" name="phone" placeholder="Phone" required class="form-control"/><br/><br/>
    <input type="password" name="password" placeholder="Password" required class="form-control"/><br/><br/>
    <button type="submit" class="btn">Register</button>
  </form>
  <br/>
  <p>Already have an account? <a href="/login">Login here</a></p>
</section>
<%- include('../partials/footer') %>
